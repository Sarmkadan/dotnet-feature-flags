{
  "ConnectionStrings": {
    "DefaultConnection": "Server=(localdb)\\mssqllocaldb;Database=FeatureFlagEngine;Trusted_Connection=true;"
  },
  "FeatureFlags": {
    "EnableCache": true,
    "CacheDurationMinutes": 5,
    "AuditLogRetentionDays": 365,
    "EnableAuditLogging": true,
    "MaxRulesPerFlag": 100,
    "MaxConditionsPerRule": 50,
    "MaxVariantsPerFlag": 10,
    "LogEvaluationDetails": false,
    "DefaultRolloutPercentage": 50
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "FeatureFlags": "Debug"
    }
  },
  "AllowedHosts": "*"
}
